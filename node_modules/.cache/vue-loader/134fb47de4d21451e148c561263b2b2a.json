EACP,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC","file":"C:/inetpub/wwwroot/kvar/kvar/src/views/KvarPage.vue","sourceRoot":"","sourcesContent":["<template>\n  <q-page padding>\n    <div>\n      <div v-if=\"kvarData\">\n        <h1> kvarId: {{ kvarData.id }} </h1>\n      </div>\n      <div v-else>\n        <h2> Kvar Not Found </h2>\n      </div>\n    </div>\n  </q-page>\n</template>\n\n<script>\nimport { ref, watch } from 'vue'\nimport { useRoute } from 'vue-router'\n\nexport default {\n  name: 'KvarPage',\n\n  components: {\n    //HelloWorld\n  },\n\n  setup() {\n    const route = useRoute()\n    const kvarData = ref()\n\n\n    function fetchKvarByID(id) {\n      return {id: id}\n    }\n\n    async function routeChanged(routeParams) {\n      console.log(routeParams)\n      if(routeParams.id)\n        kvarData.value = await fetchKvarByID(routeParams.id);\n    }\n\n    routeChanged(route.params);\n\n    watch( () => route.params, () => routeChanged(route.params) )\n\n    return {\n      kvarData\n    }\n  }\n}\n</script>\n"]}]}