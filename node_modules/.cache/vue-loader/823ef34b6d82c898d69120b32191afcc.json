CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,EAAE,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;YAClH,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;QACpB,CAAC,CAAC,CAAC,CAAC,CAAC;IACT,CAAC,CAAC,CAAC,CAAC,CAAC","file":"C:/inetpub/wwwroot/kvar/kvar/src/components/KvarCircle.vue","sourceRoot":"","sourcesContent":["<template>\r\n    <div class=\"kvar-circle-container\">\r\n        <!--\r\n        <div class=\"circle\" :style=\"circleStyle\" ref=\"kvarCircle\">\r\n            <span> {{ title }} </span>\r\n        </div>\r\n        -->\r\n        <svg ref=\"kvarCircleText\" class=\"circle\" :style=\"circleStyle\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\">\r\n            <circle></circle>\r\n        </svg>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\n\r\n//import * as d3 from 'd3'\r\n//import * as d3plus from 'd3plus'\r\n\r\n//import { textWrap } from 'd3plus-text'\r\n//import { Shape } from 'd3plus-shape'\r\nimport { TextBox, fontExists } from 'd3plus-text'\r\n\r\nimport { colors } from 'quasar'\r\nconst { hexToRgb } = colors\r\nconst textColorByBackgroundRGB = rgb => !rgb||((rgb.r * 299 + rgb.g * 587 + rgb.b * 114) / 1000 > 125) ? 'black' : 'white'\r\n\r\nexport default {\r\n    name: 'KvarCircle',\r\n    props: {\r\n        /*kvarData: {\r\n            type: Object,\r\n            required: true\r\n        }*/\r\n        color: {\r\n            type: String\r\n        },\r\n        size: {\r\n            type: Number,\r\n            default: 250\r\n        }\r\n    },\r\n    setup(props, { slots }) {\r\n        // Please note that we need to explicitly expose ref value here\r\n        const kvarCircleText = ref(null)\r\n        const circleStyle = ref(null)\r\n        const title = ref(null)\r\n\r\n        \r\n\r\n        onMounted(() => {\r\n            const size = props.size\r\n            const backgroundColor = props.color||\"\"\r\n            const textColor = textColorByBackgroundRGB( hexToRgb(backgroundColor) )\r\n\r\n            title.value = slots.default()[0].children\r\n\r\n            const style = { '--size': size+'px' }\r\n            circleStyle.value = backgroundColor?{'--bgColor':backgroundColor, ...style}:style\r\n\r\n            let data = [{ text: title.value }]\r\n            \r\n            let tb = new TextBox()\r\n                .select(kvarCircleText.value)\r\n                .data(data)\r\n                .fontResize(true)\r\n                .fontMin(5)\r\n                .fontMax(25)\r\n                .fontWeight(400)\r\n                .fontFamily('monospace')\r\n                .fontColor( textColor )\r\n                .width(80).height(80).x(10).y(10)\r\n                .textAnchor(\"middle\").verticalAlign(\"middle\")\r\n                .render()\r\n\r\nconsole.log(fontExists(['Heebo','heebo']))\r\n            console.log( tb )\r\n            /*console.log( d3.select(\"#kvarCircleText\").data() )\r\n            console.log( d3.select(kvarCircleText.value) )\r\n            console.log( kvarCircleText.value )*/\r\n\r\n          // d3plus.textWrap().container(kvarCircleText.value).wrap(true).resize(true).fontSizeRange([18, 28]).draw();\r\n\r\n\r\n           //console.log( textWrap().config( { \"resize\": true } ) )\r\n           //textWrap(title).shape('circle').wrap(true).resize(true).fontSizeRange([18, 28]).draw();\r\n        })\r\n\r\n        \r\n        \r\n\r\n        return {\r\n            circleStyle,\r\n            title,\r\n            kvarCircleText\r\n        }\r\n\r\n        /*() => \r\n            h(\r\n                'div',\r\n                {\r\n                    class:'circle',\r\n                    style: {\r\n                        '--size':'200px'\r\n                    }\r\n                },\r\n                h('span',title.value)\r\n            )*/\r\n    }\r\n}\r\n</script>\r\n\r\n<style>\r\n    .circle {\r\n        --bgColor: var(--q-accent);\r\n\r\n        margin: auto;\r\n        height: var(--size);\r\n        width: var(--size);\r\n        fill: var(--bgColor);\r\n    }\r\n\r\n    .circle circle {\r\n        r: 50;\r\n        cx: 50;\r\n        cy: 50;\r\n    }\r\n</style>"]}]}