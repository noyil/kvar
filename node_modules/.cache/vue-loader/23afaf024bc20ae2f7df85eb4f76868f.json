n                <div class=\"text-subtitle2 q-px-xs\">{{ kvarData.author }}</div>\r\n            </div>\r\n        </div>\r\n\r\n\r\n         <!-- <q-card horizontal flat>\r\n            <q-card-actions align=\"center\">\r\n                <q-btn flat round color=\"accent\" :icon=\"mdiPencil\"></q-btn>\r\n                <q-btn flat round color=\"accent\" :icon=\"mdiMessage\"></q-btn>\r\n            </q-card-actions>\r\n        </q-card> -->\r\n    </div>\r\n</template>\r\n\r\n<script>\r\n  //import { ref, reactive } from 'vue'\r\n    import {\r\n        mdiPencil,\r\n        mdiMessage,\r\n        mdiHome,\r\n    } from '@quasar/extras/mdi-v5'\r\n\r\n\r\n  export default {\r\n    name: 'KvarPage',\r\n\r\n    components: {\r\n        //HelloWorld\r\n    },\r\n\r\n    props: {\r\n        kvarData: {\r\n            type: Object,\r\n            required: true\r\n        }\r\n    },\r\n\r\n    created () {\r\n        this.mdiPencil = mdiPencil\r\n        this.mdiMessage = mdiMessage\r\n        this.mdiHome = mdiHome\r\n    },\r\n\r\n    setup(props) {\r\n        //const readersNumber = ref(0)\r\n        //const book = reactive({ title: 'Vue 3 Guide' })\r\n\r\n\r\n        function getTextWidth(text, font) {\r\n            let canvas = getTextWidth.canvas || (getTextWidth.canvas = document.createElement(\"canvas\"));\r\n            let context = canvas.getContext(\"2d\");\r\n            context.font = font;\r\n            let metrics = context.measureText(text);\r\n            return metrics.width;\r\n        }\r\n\r\n        const titleWidth = getTextWidth(props.kvarData.title, \"20pt Arial\")\r\n        console.log( titleWidth )\r\n\r\n        let paddingTop = 0\r\n        if(titleWidth<295) paddingTop = '110px'\r\n        else if(titleWidth<470) paddingTop = '92px'\r\n        else if(titleWidth<715) paddingTop = '75px'\r\n        else if(titleWidth<970) paddingTop = '60px'\r\n        else if(titleWidth<1100) paddingTop = '32px'\r\n        else paddingTop = '0px'\r\n\r\n        const circleTextStyle = { '--paddingTop':paddingTop }\r\n        const circleStyles = props.kvarData.color?{'--centerColor':props.kvarData.color, ...circleTextStyle}:circleTextStyle\r\n        // expose to template\r\n        return {\r\n            circleStyles\r\n        }\r\n    }\r\n  }\r\n</script>\r\n\r\n<style scoped>\r\n    .kvar-card-container {\r\n        overflow: hidden;\r\n    }\r\n\r\n\r\n\r\n    .kvar-circle-svg {\r\n        width: 600px;\r\n        height: 200px;\r\n        background-color: yellow;\r\n    }\r\n    .kvar-circle-svg foreignObject \r\n    .circle {\r\n        background-color: blue;\r\n        height: 100%;\r\n        border-radius: 100%;\r\n        border-width: 15px;\r\n        border-color: red;\r\n        text-align: center;\r\n        line-height: 200px;\r\n        font-size: 30px;\r\n    }\r\n    .circle span {\r\n        line-height: normal;\r\n        display:inline-block;\r\n        vertical-align: middle;\r\n        color: white;\r\n        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);\r\n    }\r\n\r\n\r\n\r\n\r\n\r\n/*\r\n    .kvar-circle {\r\n        font-size: 2000%;\r\n    }\r\n*/\r\n    .q-circular-progress__center {\r\n        color: var(--centerColor);\r\n    }\r\n\r\n    .kvar-circle-container-left {\r\n        height: 100%;\r\n        width: 100%;\r\n    }\r\n    .kvar-circle-container-right {\r\n        height: 100%;\r\n        line-height: 120%;\r\n        padding: 0;\r\n        text-align: center;\r\n    }\r\n    .kvar-circle-title{\r\n        padding-top: var(--paddingTop);\r\n    }\r\n    .kvar-circle-container-left::before {\r\n        content: \"\";\r\n        float: right;\r\n        height: 100%;\r\n        width: 50%;\r\n        shape-margin: 7%;\r\n        shape-outside: polygon(\r\n            0 0,\r\n            98% 0,\r\n            50% 6%,\r\n            23.4% 17.3%,\r\n            6% 32.6%,\r\n            0 50%,\r\n            6% 65.6%,\r\n            23.4% 82.7%,\r\n            50% 94%,\r\n            98% 100%,\r\n            0 100%\r\n        );\r\n    }\r\n    .kvar-circle-container-right::before {\r\n        content: \"\";\r\n        float: left;\r\n        height: 100%;\r\n        width: 50%;\r\n        shape-margin: 7%;\r\n        shape-outside: polygon(\r\n            2% 0%,\r\n            100% 0%,\r\n            100% 100%,\r\n            2% 100%,\r\n            50% 94%,\r\n            76.6% 82.7%,\r\n            94% 65.6%,\r\n            100% 50%,\r\n            94% 32.6%,\r\n            76.6% 17.3%,\r\n            50% 6%\r\n        );\r\n    }\r\n</style>"]}]}