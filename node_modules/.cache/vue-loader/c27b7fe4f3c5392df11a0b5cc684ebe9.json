">\r\n            <circle class=\"like\"/>\r\n            <circle class=\"dislike\"/>\r\n            <circle class=\"segment like\"/>\r\n            <circle class=\"segment dislike\"/>\r\n        </svg>\r\n        <transition name=\"fade\">\r\n            <div v-if=\"editMode\" class=\"click-outside\" @click.self=\"edit(false)\"></div>\r\n        </transition>\r\n        <svg ref=\"kvarCircleSvg\" class=\"circle\" :style=\"circleStyle\" viewBox=\"0 0 400 400\">\r\n            <circle @click=\"edit(true)\"/>\r\n            <circle class=\"status-circle\" @click=\"edit(true)\"/>\r\n\r\n            <foreignObject v-if=\"editMode\" v-bind=\"textTransforms.title\" >\r\n                <KvarCircleTitleInput v-model.trim=\"editableTitle\" :fontMinMax=\"textTransforms.fontSizes\" @keydown.enter.prevent @keyup.enter=\"edit(false,true)\"/>\r\n            </foreignObject>\r\n\r\n            <foreignObject v-if=\"editMode\" v-bind=\"textTransforms.confirmTitle\">\r\n                <q-btn round size=\"lg\" color=\"primary\" text-color=\"accent\" :icon=\"mdiCheck\" @click=\"edit(false,true)\" />\r\n            </foreignObject>\r\n        </svg>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport KvarCircleTitleInput from '@/components/KvarCircleTitleInput.vue'\r\nimport { mdiCheck } from '@quasar/extras/mdi-v5'\r\nimport { ref, watch, onMounted } from 'vue'\r\nimport { TextBox } from 'd3plus-text'\r\nimport { colors } from 'quasar'\r\nconst { hexToRgb } = colors\r\n\r\nexport default {\r\n    name: 'KvarCircle',\r\n    props: {\r\n       // modelValue: { type: Object }\r\n        title   : { type: String , required: true },\r\n        status  : { type: String , required: true },\r\n        color   : { type: String , default: \"\"    },\r\n        editMode: { type: Boolean, default: false }\r\n    },\r\n    components: {\r\n        KvarCircleTitleInput\r\n    },\r\n    setup(props, { emit }) {\r\n        const kvarCircleSvg   = ref(null)\r\n        const circleStyle     = ref(null)\r\n        const likeStyle       = ref(null)\r\n\r\n        const backgroundColor = ref(props.color)\r\n        const editableTitle   = ref(props.title)\r\n        const status          = ref(props.status)\r\n\r\n        const updateLikeStyle = (likes, dislikes) => {\r\n            const sum = (likes + dislikes)/100\r\n            const likePercentage = parseInt(Math.round(likes/sum))\r\n            const dislikePercentage = parseInt(Math.round(dislikes/sum))\r\n            likeStyle.value = {\r\n                '--likes': `${likePercentage} ${100-likePercentage}`,\r\n                '--dislikes': `0 ${100-dislikePercentage} ${dislikePercentage} 0`\r\n            }\r\n        }\r\n\r\n        const textColorByBackgroundRGB = rgb => !rgb||((rgb.r * 299 + rgb.g * 587 + rgb.b * 114) / 1000 > 145) ? 'black' : 'white'\r\n        const updateCircleStyle = () => circleStyle.value = {\r\n            '--bgColor'            : props.color,\r\n            '--statusBgColor'      : 'rgba(0,0,0,0.3)',\r\n            '--textColor'          : textColorByBackgroundRGB( hexToRgb( props.color ) ),\r\n            ...props.editMode ? {\r\n                '--titleDisplayMode'   : 'none',\r\n                '--textareaDisplayMode': 'unset',\r\n                '--borderWidth': '5px',\r\n                '--scale': '1.1'\r\n            } : {\r\n                '--titleDisplayMode'   : 'unset',\r\n                '--textareaDisplayMode': 'none',\r\n                '--borderWidth': '0px',\r\n                '--scale': '1.0'\r\n            }\r\n        }\r\n\r\n        const textTransforms = {\r\n            title       : { height: 220, width: 320, x: 40 , y: 80  },\r\n            status      : { height: 80 , width: 240, x: 80 , y: 292 }, \r\n            confirmTitle: { height: 60 , width: 60 , x: 170, y: 300, overflow: 'visible' },\r\n            fontSizes   : { min: 14, max: 40, current: 40 }\r\n        }\r\n\r\n        const generateCircleTextData = () => [\r\n            {\r\n                id: 'title', text: props.title,\r\n                resize: true, min: 14, max: 40,\r\n                ...textTransforms.title\r\n            }, {\r\n                id: 'status', text: props.status,\r\n                resize: true, min: 40, max: 100,\r\n                ...textTransforms.status\r\n            }\r\n        ]\r\n\r\n        const setFontSize = () => { textTransforms.fontSizes.current = parseFloat(kvarCircleSvg.value.querySelector(\"#d3plus-textBox-title text\").style.fontSize) }\r\n        const removeTextboxes = () => kvarCircleSvg.value.querySelectorAll(\".d3plus-textBox\").forEach( element => element.remove() )\r\n        const updateTextboxes = () => {\r\n            if(props.editMode) return\r\n            removeTextboxes()\r\n            new TextBox()\r\n                .data( generateCircleTextData() )\r\n                .fontResize(data=>data.resize).fontMin(data=>data.min).fontMax(data=>data.max)\r\n                .fontFamily(['Heebo','heebo']).fontWeight(400)\r\n                .textAnchor(\"middle\").verticalAlign(\"middle\")\r\n                .select(kvarCircleSvg.value).id(data=>data.id).render(setFontSize)\r\n        }\r\n        \r\n        const renderCircle = () => {\r\n            updateLikeStyle(70,30)\r\n            updateCircleStyle()\r\n            updateTextboxes()\r\n        }\r\n\r\n        watch([()=>props.editMode, backgroundColor], updateCircleStyle)\r\n        watch([status, ()=>props.title], updateTextboxes)\r\n        \r\n        onMounted(() => renderCircle() )\r\n        //onUpdated(() => renderCircle)\r\n\r\n        const edit = (value, confirm) => {\r\n            if(props.editMode != value)\r\n                emit(\"update:editMode\", value)\r\n            if(confirm && editableTitle.value.length>3 && editableTitle.value != props.title)\r\n                emit(\"update:title\", editableTitle.value)\r\n            else\r\n                editableTitle.value = props.title\r\n        }\r\n\r\n        return {\r\n            circleStyle,\r\n            likeStyle,\r\n            kvarCircleSvg,\r\n            textTransforms,\r\n            editableTitle,\r\n            edit,\r\n            mdiCheck\r\n        }\r\n    }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n    .kvar-circle-container {\r\n        position: relative;\r\n    }\r\n    .circle-behind {\r\n        position: absolute;\r\n        overflow: hidden;\r\n        border-radius: 50%;\r\n        margin: -10%;\r\n    }\r\n    .circle-behind circle {\r\n        r: 15%;\r\n        stroke-width: 0;\r\n        transition: r 0.2s ease-in-out;\r\n    }\r\n    .circle-behind .like {\r\n        cy: 20%;\r\n        cx: 80%;\r\n        fill: #84ea9f;\r\n        stroke:#84ea9f;\r\n        stroke-dasharray: var(--likes);\r\n    }\r\n    .circle-behind .dislike {\r\n        cy: 20%;\r\n        cx: 20%;\r\n        fill: rgb(230, 157, 157);\r\n        stroke: rgb(230, 157, 157);\r\n        stroke-dasharray: var(--dislikes);\r\n    }\r\n    .circle-behind .segment {\r\n        fill: none;\r\n        cy: 50%;\r\n        cx: 50%;\r\n        r: 42%;\r\n        stroke-width: 2%;\r\n        stroke-dashoffset: 25;\r\n        transition: stroke-dasharray 0.2s ease-in-out;\r\n    }\r\n    .circle {\r\n        --bgColor: var(--q-accent);\r\n\r\n        position: relative;\r\n        z-index: 4000;\r\n\r\n        overflow: hidden;\r\n        border-radius: 50%;\r\n        border: solid var(--borderWidth) var(--q-primary);\r\n        box-shadow: 0 8px 12px 0 rgba(0, 0, 0, 0.3), 0 4px 40px 0 rgba(0, 0, 0, 0.2);\r\n\r\n        transform: scale( var(--scale) );\r\n        transition: transform 0.2s ease-in-out, border 0.2s ease-in-out;\r\n    }\r\n    .circle circle {\r\n        fill: var(--bgColor);\r\n        r: 50%;\r\n        cx: 50%;\r\n        cy: 50%;\r\n    }\r\n    .circle .status-circle {\r\n        fill: var(--statusBgColor);\r\n        cy: 121%;\r\n    }\r\n    .circle text {\r\n        unicode-bidi: unset !important;\r\n        pointer-events: none;\r\n        fill: var(--textColor);\r\n    }\r\n    #d3plus-textBox-title, #d3plus-textBox-status {\r\n        display: var(--titleDisplayMode);\r\n    }\r\n\r\n    .click-outside {\r\n        position: fixed;\r\n        top: 0; left: 0; right: 0; bottom: 0;\r\n        background-color: rgba(0,0,0,0.3);\r\n        background: radial-gradient(circle at center, rgba(0,0,0,0.1) 25%, rgba(0,0,0,0.6) 90%);\r\n        z-index: 3000;\r\n    }\r\n</style>"]}]}