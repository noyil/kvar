r\n        }*/\r\n        color: {\r\n            type: String\r\n        }\r\n    },\r\n    setup(props, { slots }) {\r\n        // Please note that we need to explicitly expose ref value here\r\n        const kvarCircleText   = ref(null)\r\n        const circleStyle = ref(null)\r\n        const title = ref(null)\r\n\r\n        \r\n\r\n        onMounted(() => {\r\n            title.value = slots.default()\r\n            const style = { '--size':'200px' }\r\n            circleStyle.value = props.color?{'--color':props.color, ...style}:style\r\n\r\n            //console.log(d3)\r\n            //console.log(d3plus)\r\n          // d3plus.textWrap().container(kvarCircleText.value).wrap(true).resize(true).fontSizeRange([18, 28]).draw();\r\n           \r\n           var data = [ {text: \"This is a sentence that will not be resized.\", resize: false} ]\r\n            new TextBox()\r\n                .data(data)\r\n                .fontResize(function(d) { return d.resize; })\r\n                .height(100)\r\n                .width(200)\r\n                .x(function(d, i) { return i * 250; })\r\n                .render();\r\n\r\n\r\n           //console.log( textWrap().config( { \"resize\": true } ) )\r\n           //textWrap(title).shape('circle').wrap(true).resize(true).fontSizeRange([18, 28]).draw();\r\n        })\r\n\r\n        \r\n        \r\n\r\n        return {\r\n            circleStyle,\r\n            title,\r\n            kvarCircleText\r\n        }\r\n\r\n        /*() => \r\n            h(\r\n                'div',\r\n                {\r\n                    class:'circle',\r\n                    style: {\r\n                        '--size':'200px'\r\n                    }\r\n                },\r\n                h('span',title.value)\r\n            )*/\r\n    }\r\n}\r\n</script>\r\n\r\n<style>\r\n    .circle {\r\n        --color: var(--q-accent);\r\n\r\n        margin: auto;\r\n        height: var(--size);\r\n        width: var(--size);\r\n        \r\n        border-radius: 50%;\r\n        font-size: 30px;\r\n        fill: var(--color);\r\n        text-align: center;\r\n        position: relative;\r\n    }\r\n\r\n    .circle span {\r\n        position: absolute;\r\n        left: 50%;\r\n        top: 50%;\r\n        -ms-transform: translate(-50%, -50%);\r\n        -webkit-transform: translate(-50%, -50%);\r\n        transform: translate(-50%, -50%);\r\n    }\r\n</style>"]}]}