C,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;IACpC","file":"C:/inetpub/wwwroot/kvar/kvar/src/components/KvarCircle.vue","sourceRoot":"","sourcesContent":["<template>\r\n    <div\r\n        class=\"kvar-circle-container\"\r\n        @click=\"edit(true)\"\r\n        v-click-outside=\"edit(false)\"\r\n    >\r\n        <svg\r\n            ref=\"kvarCircleSvg\"\r\n            class=\"circle\"\r\n            :style=\"circleStyle\"\r\n            viewBox=\"0 0 400 400\"\r\n        >\r\n            <circle r=200 cx=200 cy=200></circle>\r\n            <foreignObject x=\"40\" y=\"80\" width=\"320\" height=\"220\">\r\n                <KvarCircleTitleInput v-if=\"state.inEditMode\" v-model=\"editableTitle\"/>\r\n            </foreignObject>\r\n        </svg>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport KvarCircleTitleInput from '@/components/KvarCircleTitleInput.vue'\r\n\r\nimport { ref, watch, reactive, onMounted } from 'vue'\r\nimport { TextBox } from 'd3plus-text'\r\nimport { colors } from 'quasar'\r\nconst { hexToRgb } = colors\r\nconst textColorByBackgroundRGB = rgb => !rgb||((rgb.r * 299 + rgb.g * 587 + rgb.b * 114) / 1000 > 135) ? 'black' : 'white'\r\n\r\nexport default {\r\n    name: 'KvarCircle',\r\n    props: {\r\n        title: {\r\n            type: String,\r\n            required: true\r\n        },\r\n        status: {\r\n            type: String,\r\n            required: true\r\n        },\r\n        color: {\r\n            type: String,\r\n            default: \"\"\r\n        }\r\n    },\r\n    setup(props) {\r\n        const kvarCircleSvg   = ref(null)\r\n        const circleStyle     = ref(null)\r\n\r\n        const inEditMode      = ref(false)\r\n        const backgroundColor = ref(props.color)\r\n        const textColor       = ref('white')\r\n        const editableTitle   = ref(props.title)\r\n        const status          = ref(props.status)\r\n\r\n        const state = reactive({ inEditMode, backgroundColor, editableTitle, status })\r\n\r\n        const generateCircleStyle = () => { return {\r\n            '--bgColor': state.backgroundColor,\r\n            '--textColor': textColor.value,\r\n            '--titleDisplayMode': state.inEditMode?'none':'unset',\r\n            '--textareaDisplayMode': state.inEditMode?'unset':'none'\r\n        } }\r\n\r\n        watch(backgroundColor, newValue => textColor.value = textColorByBackgroundRGB( hexToRgb(newValue) ) )\r\n\r\n        watch(state, () => circleStyle.value = generateCircleStyle() )\r\n\r\n        onMounted(() => {\r\n            circleStyle.value = generateCircleStyle()\r\n\r\n            let data = [\r\n                {\r\n                    id: 'title',\r\n                    text: editableTitle.value,\r\n                    height: 220,\r\n                    width: 320,\r\n                    x: 40,\r\n                    y: 80,\r\n                    resize: true,\r\n                    fontMin: 14,\r\n                    fontMax: 48\r\n                },\r\n                {\r\n                    id: 'status',\r\n                    text: status.value,\r\n                    height: 80,\r\n                    width: 240,\r\n                    x: 80,\r\n                    y: 292,\r\n                    resize: true,\r\n                    fontMin: 40,\r\n                    fontMax: 100\r\n                }\r\n            ]\r\n\r\n            new TextBox()\r\n                .data(data)\r\n                .fontResize(data=>data.resize)\r\n                .fontMin(data=>data.fontMin)\r\n                .fontMax(data=>data.fontMax)\r\n                .fontWeight(400)\r\n                .fontFamily(['Heebo','heebo'])\r\n                .fontColor( textColor.value )\r\n                .textAnchor(\"middle\").verticalAlign(\"middle\")\r\n                .pointerEvents(\"none\")\r\n                .select(kvarCircleSvg.value)\r\n                .id(data=>data.id)\r\n                .render()\r\n        })\r\n\r\n        const edit = value => { inEditMode.value = value; console.log(value) }\r\n\r\n        return {\r\n            circleStyle,\r\n            kvarCircleSvg,\r\n            editableTitle,\r\n            KvarCircleTitleInput,\r\n            edit,\r\n            state\r\n        }\r\n    }\r\n}\r\n</script>\r\n\r\n<style>\r\n    .circle {\r\n        --bgColor: var(--q-accent);\r\n        fill: var(--bgColor);\r\n        margin: auto;\r\n    }\r\n    .circle text {\r\n        unicode-bidi: unset !important;\r\n    }\r\n    #d3plus-textBox-title, #d3plus-textBox-status {\r\n        display: var(--titleDisplayMode);\r\n    }\r\n</style>"]}]}