C,CAAC,CAAC,EAAE,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC;QACvF,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC;IACjB","file":"C:/inetpub/wwwroot/kvar/kvar/src/components/KvarCircleRanking.vue","sourceRoot":"","sourcesContent":["<template>\r\n    <svg class=\"circle-behind no-pointer-events\" viewBox=\"0 0 37.894 37.894\" :style=\"rankingStyle\">\r\n        <circle class=\"negative all-pointer-events\" @click=\"vote(false)\"/>\r\n        <circle class=\"positive all-pointer-events\" @click=\"vote(true)\"/>\r\n        <path :d=\"mdiThumbDown\" class=\"negative-icon\"/>\r\n        <path :d=\"mdiThumbUp\" class=\"positive-icon\"/>\r\n        <circle class=\"segment neutral\"/>\r\n        <circle class=\"segment negative\"/>\r\n        <circle class=\"segment positive\"/>\r\n    </svg>\r\n</template>\r\n\r\n<script>\r\nimport { mdiThumbUp, mdiThumbDown } from '@quasar/extras/mdi-v5'\r\nimport { ref, watch, onMounted } from 'vue'\r\n\r\nexport default {\r\n    name: 'KvarCircleRanking',\r\n    props: {\r\n        visible      : { type: Boolean, default: true },\r\n        voted        : { type: String , default: undefined },\r\n        positiveVotes: { type: Number , default: 0    },\r\n        negativeVotes: { type: Number , default: 0    },\r\n        color        : { type: String , default: \"\"   }\r\n    },\r\n    setup(props, { emit }) {\r\n        const rankingStyle    = ref({})\r\n        const backgroundColor = ref(props.color)\r\n\r\n\r\n        const updateRankingStyle = () => {\r\n            rankingStyle.value['--r']       = props.visible?'15%':'0%'\r\n            rankingStyle.value['--bgColor'] = backgroundColor.value\r\n        }\r\n\r\n        const updateVotesStyle = () => {\r\n            const positive = props.positiveVotes || 0\r\n            const negative = props.negativeVotes || 0\r\n            const sum = positive + negative\r\n            const perimeter = sum ? (Math.max( 0 , Math.min( sum, 100 ) ) / sum) : 0 \r\n            const positivePercentage = parseInt(Math.round(positive * perimeter))\r\n            const negativePercentage = parseInt(Math.round(negative * perimeter))\r\n            rankingStyle.value = {\r\n                '--positive': `${positivePercentage} ${100-positivePercentage}`,\r\n                '--negative': `0 ${100-negativePercentage} ${negativePercentage} 0`,\r\n                '--r'       : props.visible?'15%':'0%'\r\n            }\r\n        }\r\n/*\r\n        const rankingTransforms = {\r\n            title       : { height: 220, width: 320, x: 40 , y: 80  },\r\n            status      : { height: 80 , width: 240, x: 80 , y: 292 }, \r\n            confirmTitle: { height: 60 , width: 60 , x: 170, y: 300, overflow: 'visible' },\r\n            fontSizes   : { min: 14, max: 40, current: 40 }\r\n        }\r\n*/\r\n        watch([()=>props.visible, ()=>props.color, ()=>props.voted], updateRankingStyle)\r\n        watch([()=>props.positiveVotes, ()=>props.negativeVotes], updateVotesStyle)\r\n\r\n        onMounted(() => {\r\n            updateRankingStyle()\r\n            updateVotesStyle()\r\n        } )\r\n\r\n        const vote = value => {\r\n            if(value)\r\n                emit('update:positiveVotes', props.positiveVotes+1 )\r\n            else\r\n                emit('update:negativeVotes', props.negativeVotes+1 )\r\n        }\r\n\r\n        return {\r\n            rankingStyle,\r\n            vote,\r\n            mdiThumbUp, mdiThumbDown\r\n        }\r\n    }\r\n}\r\n</script>\r\n\r\n<style>\r\n    .circle-behind {\r\n        --r: 15%;\r\n        position: absolute;\r\n        overflow: hidden;\r\n        border-radius: 50%;\r\n        margin: -10%;\r\n    }\r\n    .circle-behind circle {\r\n        r: var(--r);\r\n        stroke-width: 0;\r\n        transition: r 0.2s ease-in-out, filter 0.2s ease-in-out, fill 0.2s ease-in-out;\r\n        fill: var(--bgColor);\r\n    }\r\n    .circle-behind circle:hover {\r\n        r: 18%;\r\n        cursor: pointer;\r\n        filter: brightness(0.9);\r\n        position: relative;\r\n    }\r\n    .circle-behind circle:active {\r\n        r: 100%;\r\n        filter: brightness(1.1);\r\n    }\r\n    .circle-behind circle.positive:active  {\r\n        fill:#63d682;\r\n    }\r\n    .circle-behind circle.negative:active  {\r\n        fill:rgb(224, 128, 128);\r\n    }\r\n    .circle-behind .positive {\r\n        cy: 20%;\r\n        cx: 80%;\r\n        stroke:#63d682;\r\n        stroke-dasharray: var(--positive);\r\n    }\r\n    .circle-behind .negative {\r\n        cy: 20%;\r\n        cx: 20%;\r\n        stroke: rgb(224, 128, 128);\r\n        stroke-dasharray: var(--negative);\r\n    }\r\n    .circle-behind .positive-icon, .circle-behind .negative-icon {\r\n        fill: white;\r\n        transform: translate(-80.25%, 14.75%) scale(0.075);\r\n    }\r\n    .circle-behind .negative-icon {\r\n        transform: translate(-15.25%, 15.25%) scale(0.075);\r\n    }\r\n    .circle-behind .segment {\r\n        fill: none;\r\n        cy: 50%;\r\n        cx: 50%;\r\n        r: 42%;\r\n        stroke-width: 2%;\r\n        stroke-dashoffset: 25;\r\n\r\n        transition: stroke-dasharray 0.2s ease-in-out;\r\n    }\r\n    .circle-behind .neutral {\r\n        stroke: rgb(0, 0, 0);\r\n        stroke-width: 1.5%;\r\n        opacity: 0.15;\r\n    }\r\n    /\r\n    .circle {\r\n        position: relative;\r\n        z-index: 4000;\r\n\r\n        overflow: hidden;\r\n        border-radius: 50%;\r\n        border: solid var(--borderWidth) var(--q-primary);\r\n        box-shadow: 0 8px 12px 0 rgba(0, 0, 0, 0.3), 0 4px 40px 0 rgba(0, 0, 0, 0.2);\r\n\r\n        transform: scale( var(--scale) );\r\n        transition: transform 0.2s ease-in-out, border 0.2s ease-in-out;\r\n    }\r\n    .circle circle {\r\n        fill: var