AAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC;YAC3G,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;QACnB,CAAC,CAAC,CAAC,CAAC,CAAC;IACT,CAAC,CAAC,CAAC,CAAC,CAAC","file":"C:/inetpub/wwwroot/kvar/kvar/src/components/KvarCircle.vue","sourceRoot":"","sourcesContent":["<template>\r\n    <div class=\"kvar-circle-container\">\r\n\r\n        <br/>KvarCircle:<br/>\r\n        props.title: {{ title }} <br/>\r\n        editableTitle: {{ editableTitle }} <br/>\r\n\r\n        <div v-if=\"state.inEditMode\" class=\"click-outside\" @click.self=\"edit(false)\"></div>\r\n        \r\n        <svg ref=\"kvarCircleSvg\" class=\"circle\" :style=\"circleStyle\" viewBox=\"0 0 400 400\">\r\n            <circle r=\"50%\" cx=\"50%\" cy=\"50%\" @click=\"edit(true)\"/>\r\n\r\n            <foreignObject v-if=\"state.inEditMode\" v-bind=\"textTransforms.title\" >\r\n                <KvarCircleTitleInput v-model=\"editableTitle\"/>\r\n            </foreignObject>\r\n\r\n            <foreignObject v-if=\"state.inEditMode\" v-bind=\"textTransforms.confirmTitle\">\r\n                <q-btn round size=\"lg\" color=\"primary\" text-color=\"accent\" :icon=\"mdiCheck\" @click=\"edit(false,true)\" />\r\n            </foreignObject>\r\n        </svg>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport KvarCircleTitleInput from '@/components/KvarCircleTitleInput.vue'\r\nimport { mdiCheck } from '@quasar/extras/mdi-v5'\r\nimport { ref, watch, reactive, onMounted } from 'vue'\r\nimport { TextBox } from 'd3plus-text'\r\nimport { colors } from 'quasar'\r\nconst { hexToRgb } = colors\r\n\r\nexport default {\r\n    name: 'KvarCircle',\r\n    props: {\r\n       // modelValue: { type: Object }\r\n        title : { type: String, required: true },\r\n        status: { type: String, required: true },\r\n        color : { type: String, default: \"\" } \r\n    },\r\n    setup(props, { emit }) {\r\n        const kvarCircleSvg   = ref(null)\r\n        const circleStyle     = ref(null)\r\n\r\n        const inEditMode      = ref(false)\r\n        const backgroundColor = ref(props.color)\r\n        const editableTitle   = ref(props.title)\r\n        const status          = ref(props.status)\r\n        const state           = reactive({inEditMode, backgroundColor, status})\r\n\r\n        const textColorByBackgroundRGB = rgb => !rgb||((rgb.r * 299 + rgb.g * 587 + rgb.b * 114) / 1000 > 145) ? 'black' : 'white'\r\n        const updateCircleStyle = () => circleStyle.value = {\r\n            '--bgColor'            : state.backgroundColor,\r\n            '--textColor'          : textColorByBackgroundRGB( hexToRgb( state.backgroundColor ) ),\r\n            '--titleDisplayMode'   : state.inEditMode ? 'none' :'unset',\r\n            '--textareaDisplayMode': state.inEditMode ? 'unset':'none'\r\n        }\r\n\r\n        const textTransforms = {\r\n            title       : { height: 220, width: 320, x: 40 , y: 80  },\r\n            status      : { height: 80 , width: 240, x: 80 , y: 292 }, \r\n            confirmTitle: { height: 60 , width: 70 , x: 160, y: 300 }\r\n        }\r\n\r\n        const generateCircleTextData = () => [\r\n            {\r\n                id: 'title', text: props.title,\r\n                resize: true, fontMin: 14, fontMax: 48,\r\n                ...textTransforms.title\r\n            }, {\r\n                id: 'status', text: state.status,\r\n                resize: true, fontMin: 40, fontMax: 100,\r\n                ...textTransforms.status\r\n            }\r\n        ]\r\n\r\n        const removeTextboxes   = () => kvarCircleSvg.value.querySelectorAll(\".d3plus-textBox\").forEach( element => element.remove() )\r\n        const updateTextboxes = () => {\r\n            console.log(\"text updated: \" + props.title)\r\n            if(state.inEditMode) return\r\n            removeTextboxes()\r\n            new TextBox()\r\n                .data( generateCircleTextData() )\r\n                .fontResize(data=>data.resize).fontMin(data=>data.fontMin).fontMax(data=>data.fontMax)\r\n                .fontFamily(['Heebo','heebo']).fontWeight(400)\r\n                .textAnchor(\"middle\").verticalAlign(\"middle\")\r\n                .select(kvarCircleSvg.value).id(data=>data.id).render()\r\n        }\r\n        \r\n        const renderCircle = () => {\r\n            updateCircleStyle();\r\n            updateTextboxes()\r\n        }\r\n\r\n        watch([inEditMode, backgroundColor], updateCircleStyle)\r\n        watch([status, ()=>props.title], updateTextboxes)\r\n        \r\n        onMounted(() => renderCircle() )\r\n        //onUpdated(() => renderCircle)\r\n\r\n        const edit = (value, confirm) => {\r\n            if(inEditMode.value != value)\r\n            inEditMode.value = value\r\n            if(confirm && editableTitle.value != props.title)\r\n                emit(\"update:title\", editableTitle.value)\r\n            else\r\n                editableTitle.value = props.title\r\n        }\r\n\r\n        return {\r\n            circleStyle,\r\n            kvarCircleSvg,\r\n            textTransforms,\r\n            editableTitle,\r\n            KvarCircleTitleInput,\r\n            edit,\r\n            state,\r\n            mdiCheck\r\n        }\r\n    }\r\n}\r\n</script>\r\n\r\n<style>\r\n    .circle {\r\n        --bgColor: var(--q-accent);\r\n        fill: var(--bgColor);\r\n        margin: auto;\r\n        position: relative;\r\n        z-index: 4000;\r\n    }\r\n    .circle text {\r\n        unicode-bidi: unset !important;\r\n        pointer-events: none;\r\n        fill: var(--textColor);\r\n    }\r\n    #d3plus-textBox-title, #d3plus-textBox-status {\r\n        display: var(--titleDisplayMode);\r\n    }\r\n\r\n    .click-outside {\r\n        position: fixed;\r\n        top: 0; left: 0; right: 0; bottom: 0;\r\n        background-color: rgba(0,0,0,0.3);\r\n        background: radial-gradient(circle at center, rgba(0,0,0,0.1) 25%, rgba(0,0,0,0.6) 90%);\r\n        z-index: 3000;\r\n    }\r\n</style>"]}]}