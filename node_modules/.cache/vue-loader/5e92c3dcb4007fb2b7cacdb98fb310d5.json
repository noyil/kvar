xt-h6\"> &nbsp; </div> -->\r\n                <div class=\"kvar-circle-container-left\">\r\n                    <div class=\"kvar-circle-container-right\">\r\n                        <div class=\"kvar-circle-title\">{{ kvarData.title }}</div>\r\n                        <div class=\"text-h4 q-pt-sm\">{{ kvarData.status }}</div>\r\n                    </div>\r\n                </div>\r\n                <!-- <div class=\"text-h4 text-white\">{{ kvarData.status }}</div> -->\r\n            </div>\r\n        </q-circular-progress>\r\n\r\n       <div class=\"full-width row no-wrap items-center justify-between\">\r\n           <div class=\"row\">\r\n                <q-btn flat round color=\"accent\" :icon=\"mdiMessage\"></q-btn>\r\n                <q-btn flat round color=\"accent\" :icon=\"mdiPencil\"></q-btn>\r\n            </div>\r\n            <div class=\"row q-pt-sm\">\r\n                <div class=\"text-subtitle2 q-px-sm\">{{ kvarData.lastModifiedDate }}</div>\r\n                <div class=\"text-subtitle2 q-px-xs\">{{ kvarData.author }}</div>\r\n            </div>\r\n        </div>\r\n\r\n\r\n         <!-- <q-card horizontal flat>\r\n            <q-card-actions align=\"center\">\r\n                <q-btn flat round color=\"accent\" :icon=\"mdiPencil\"></q-btn>\r\n                <q-btn flat round color=\"accent\" :icon=\"mdiMessage\"></q-btn>\r\n            </q-card-actions>\r\n        </q-card> -->\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\nimport KvarCircle from '@/components/KvarCircle.vue'\r\nimport {\r\n    mdiPencil,\r\n    mdiMessage,\r\n    mdiHome,\r\n} from '@quasar/extras/mdi-v5'\r\n\r\n\r\n  export default {\r\n    name: 'KvarPage',\r\n\r\n    components: {\r\n        KvarCircle\r\n    },\r\n\r\n    props: {\r\n        kvarData: {\r\n            type: Object,\r\n            required: true\r\n        }\r\n    },\r\n\r\n    created () {\r\n        this.mdiPencil = mdiPencil\r\n        this.mdiMessage = mdiMessage\r\n        this.mdiHome = mdiHome\r\n    },\r\n\r\n    setup(props) {\r\n        //const readersNumber = ref(0)\r\n        //const book = reactive({ title: 'Vue 3 Guide' })\r\n\r\n        const kvarCircle   = ref(null)\r\n        const circleStyles = ref(null)\r\n\r\n        function getTextWidth(text, font) {\r\n            let canvas = getTextWidth.canvas || (getTextWidth.canvas = document.createElement(\"canvas\"));\r\n            let context = canvas.getContext(\"2d\");\r\n            context.font = font;\r\n            let metrics = context.measureText(text);\r\n            return metrics.width;\r\n        }\r\n\r\n        onMounted(() => {\r\n            const titleWidth = getTextWidth(props.kvarData.title, \"20pt Arial\")\r\n\r\n            let paddingTop = 0\r\n            let lineHeight = 2.0\r\n            if     (titleWidth < 295)  { paddingTop = '110px', lineHeight = 2.0  }\r\n            else if(titleWidth < 470)  { paddingTop = '92px' , lineHeight = 2.0  }\r\n            else if(titleWidth < 715)  { paddingTop = '75px' , lineHeight = 2.0  }\r\n            else if(titleWidth < 970)  { paddingTop = '60px' , lineHeight = 1.85 }\r\n            else if(titleWidth < 1100) { paddingTop = '32px' , lineHeight = 1.75 }\r\n            else if(titleWidth < 1470) { paddingTop = '0px'  , lineHeight = 1.65 }\r\n            else if(titleWidth < 1700) { paddingTop = '0px'  , lineHeight = 1.4  }\r\n            else                       { paddingTop = '0px'  , lineHeight = 1.2  }\r\n\r\n            const circleTextStyle = { '--paddingTop':paddingTop, '--titleLineHeight':lineHeight+'rem' }\r\n            circleStyles.value = props.kvarData.color?{'--centerColor':props.kvarData.color, ...circleTextStyle}:circleTextStyle\r\n        });\r\n\r\n        return {\r\n            kvarCircle,\r\n            circleStyles\r\n        }\r\n    }\r\n  }\r\n</script>\r\n\r\n<style>\r\n    .kvar-card-container {\r\n        overflow: hidden;\r\n    }\r\n\r\n    .kvar-circle {\r\n        font-size: 280px;\r\n    }\r\n    \r\n    .q-circular-progress__center {\r\n        color: var(--centerColor);\r\n    }\r\n\r\n    .kvar-circle-container-left {\r\n        height: 100%;\r\n        width: 100%;\r\n    }\r\n    .kvar-circle-container-right {\r\n        height: 100%;\r\n        line-height: 120%;\r\n        padding: 0;\r\n        text-align: center;\r\n    }\r\n    .kvar-circle-title{\r\n        padding-top: var(--paddingTop);\r\n        line-height: var(--titleLineHeight);\r\n        font-size: 20px;\r\n        letter-spacing: 0.2px;\r\n    }\r\n    .kvar-circle-container-left::before {\r\n        content: \"\";\r\n        float: right;\r\n        height: 100%;\r\n        width: 50%;\r\n        shape-margin: 7%;\r\n        shape-outside: polygon(0 0, 98% 0, 50% 6%, 23.4% 17.3%, 6% 32.6%, 0 50%, 6% 65.6%, 23.4% 82.7%, 50% 94%, 98% 100%, 0 100%);\r\n    }\r\n    .kvar-circle-container-right::before {\r\n        content: \"\";\r\n        float: left;\r\n        height: 100%;\r\n        width: 50%;\r\n        shape-margin: 7%;\r\n        shape-outside: polygon(2% 0%, 100% 0%, 100% 100%, 2% 100%, 50% 94%, 76.6% 82.7%, 94% 65.6%, 100% 50%, 94% 32.6%, 76.6% 17.3%, 50% 6%);\r\n    }\r\n</style>"]}]}